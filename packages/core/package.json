{
  "name": "@cognitivelint/core",
  "version": "0.1.1",
  "description": "Core types and scoring for CognitiveLint",
  "author": "Deepak Koul",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cognitivelint/cognitivelint.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/cognitivelint/cognitivelint#readme",
  "bugs": {
    "url": "https://github.com/cognitivelint/cognitivelint/issues"
  },
  "keywords": ["cognitivelint", "ux", "cognitive", "react", "lint"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
